{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "tags": ["triton", "llm", "trt-llm", "l4"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "title": "Triton TRT-LLM Text-IO — Serving Overview",
  "uid": "trtllm-text-io",
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s) by model",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (rate(nv_inference_count[1m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Queue depth (pending requests) by model",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model) (nv_inference_pending_request_count)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Avg inference latency (ms) by model",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model)(rate(nv_inference_request_duration_us[1m])) / clamp_min(sum by (model)(rate(nv_inference_count[1m])), 1) / 1000",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg queue latency (ms) by model",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (model)(rate(nv_inference_queue_duration_us[1m])) / clamp_min(sum by (model)(rate(nv_inference_count[1m])), 1) / 1000",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "GPU utilization (%)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "GPU power draw (W) — basis for tokens/s/W",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "watt" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "GPU {{gpu}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "TRT-LLM KV-cache blocks (used vs max)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nv_trt_llm_kv_cache_block_metrics{kv_cache_block_type=~\"used|max|free\"}",
          "legendFormat": "{{model}} {{kv_cache_block_type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Guardrail invocation rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(nv_inference_count{model=\"guardrail\"}[1m]))",
          "legendFormat": "guardrail",
          "refId": "A"
        }
      ]
    }
  ]
}
